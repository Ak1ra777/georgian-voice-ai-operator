# Portfolio-safe sample configuration.
# Copy this file to `.env` locally and replace placeholders with private values.

# Core credentials
OPENAI_API_KEY=your_openai_api_key
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-service-account.json
CARTESIA_API_KEY=your_cartesia_api_key

# OpenAI runtime
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_OUTPUT_TOKENS=120
OPENAI_TEMPERATURE=0.2

# Google STT runtime
LOCATION=eu
MODEL=chirp_3
STT_LANGUAGE_CODES=ka-GE

# Cartesia TTS runtime
TTS_PROVIDER=cartesia_ws
TTS_LANGUAGE_CODE=ka-GE
TTS_MODEL_NAME=sonic-3
TTS_AGGREGATION_MODE=token
CARTESIA_TTS_VOICE_ID=your_cartesia_voice_id
CARTESIA_GENERATION_SPEED=1.0
CARTESIA_GENERATION_VOLUME=1.0
CARTESIA_WS_SAMPLE_RATE=16000
CARTESIA_WS_ENCODING=pcm_s16le

# ISP lookup
ISP_ACCOUNT_API_URL=https://isp-lookup.example.test/account
ISP_ACCOUNT_API_KEY=your_isp_lookup_api_key
ISP_ACCOUNT_API_TIMEOUT_S=10.0

# Call behavior
CALL_NO_SPEECH_TIMEOUT_S=10
CALL_MAX_DURATION_S=3600
CALL_GREETING_ENABLED=false
CALL_GREETING_AUDIO_PATH=
USER_TURN_STOP_STRATEGY=turn_analyzer
USER_TURN_SPEECH_TIMEOUT_S=0.25
USER_TURN_STOP_TIMEOUT_S=5.0
DTMF_SUBMIT_KEY=#
IDENTIFIER_MAX_ATTEMPTS=3
VERIFICATION_MAX_ATTEMPTS=3
CALLBACK_MAX_ATTEMPTS=3

# Control / manager runtime
SIP_CONTROL_SOCKET=/tmp/demo_voice_assistant.sock
SIP_AUDIO_HOST=127.0.0.1
SIP_AUDIO_RX_PORT=4000
SIP_AUDIO_TX_PORT=4001
CONTROL_RECONNECT_GRACE_S=5
CONTROL_SOCKET_PERMS=0600
CONTROL_ALLOWED_PEER_UIDS=
CONTROL_CMD_ACK_TIMEOUT_S=0.5
CONTROL_CMD_MAX_RETRIES=3
PIPECAT_LOG_LEVEL=info
PIPECAT_ENABLE_PERIODIC_TELEMETRY=false
PIPECAT_TELEMETRY_INTERVAL_S=5.0
PIPECAT_FLOW_CONTEXT_STRATEGY=reset
CALL_ARTIFACT_SYNC_WRITES=false

# SIP gateway
SIP_DOMAIN=sip.example.test
SIP_USER=sip-user@example.test
SIP_PASS=your_sip_password
SIP_SECURITY_PROFILE=none
SIP_TRANSPORT=udp
SIP_LOCAL_PORT=5060
SIP_SRTP_MODE=disabled
SIP_SRTP_SECURE_SIGNALING=none
SIP_TLS_CA_FILE=
SIP_TLS_CERT_FILE=
SIP_TLS_KEY_FILE=
SIP_TLS_KEY_PASSWORD=
SIP_TLS_VERIFY_SERVER=false
SIP_TLS_VERIFY_CLIENT=false
SIP_TLS_REQUIRE_CLIENT_CERT=false
SIP_TLS_NEGOTIATION_TIMEOUT_MS=5000
SIP_TLS_ENABLE_RENEGOTIATION=false
SIP_AUDIO_RING_PACKETS=50
MAX_CALLS=20
CALL_READY_TIMEOUT_MS=2000
CALL_END_CLEANUP_GRACE_MS=5000
SIP_AUDIO_PORT_BASE=41000
SIP_AUDIO_PORT_COUNT=2000
